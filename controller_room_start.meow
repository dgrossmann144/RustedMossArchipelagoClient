-- find better place to intercept this flag
let game = instance_find(ogame, 0)
if (game != noone) {
  if (global.archipelago.save.starsCache == 8) {
    story_flag_set("titania_head_activated", true)
  } else {
    story_flag_set("titania_head_activated", false)
  }
}

let room = room_get()
if global.archipelago.hard_maya and room == rm_forest_boss {
  global.stars_ = 0
} else {
  global.stars_ = min(global.archipelago.save.starsCache, 7)
}

match room {
  case rm_start_0 {
    -- first spawn
    if instance_exists(ospawn_point) and global.gamestate != 29 and !global.spayer_spawned {
      global.weapon_data[0].found = 0
      global.warp_unlock_ = true
    }
  }
  case rm_snow_intro_1 {
    global.archipelago.createItem(192, 400, 0, "Grenade")
  }
  case rm_moss_top_cave {
    global.archipelago.createItem(103, 200, 0, "pickup_weapon_rm_moss_top_cave")
