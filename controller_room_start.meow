let gunPickup = instance_find(opickup_gun, 0)
if (gunPickup != noone) {
  instance_destroy(gunPickup)
}

let trinketPickup = instance_find(opickup_trinket, 0)
if (trinketPickup != noone) {
  -- can't destroy lilly trinket because the game crashes, is moved off screen every frame instead
  if (room != rm_forest_lilly) {
    instance_destroy(trinketPickup)
  }
}

-- removes grenade pickup event
let grenadePickup = instance_find(opickup_event, 0)
if (grenadePickup != noone) {
  instance_destroy(grenadePickup)
}

-- removes blocks that appear blocking the entrance to bonnie's arena
with otile_switcher_boss {
  event_perform(ev_other, ev_user0)
}

let bossMaya = instance_find(oboss_maya, 0)
if (bossMaya != noone) {
  -- if player has already beaten maya make it trivial
  if (global.archipelago.save.beatMaya) {
    bossMaya.max_hp = 1
    bossMaya.hp = 1
  }
}

-- apply shop discounts
let shop = instance_find(par_shop, 0)
let lakeShop = instance_find(oshop_lake, 0)
let faeShop = instance_find(oshop_fae, 0)
if (lakeShop != noone) {
  lakeShop.shop_data = [
    {index: 31, cost: 100 * (1 - global.archipelago.shopDiscountPercentage)},
    {index: 15, cost: 150 * (1 - global.archipelago.shopDiscountPercentage)},
    {index: 22, cost: 200 * (1 - global.archipelago.shopDiscountPercentage)}
  ]
} else if (faeShop != noone) {
  faeShop.shop_data = [
    {index: 5, cost: 100 * (1 - global.archipelago.shopDiscountPercentage)},
    {index: 10, cost: 500 * (1 - global.archipelago.shopDiscountPercentage)},
    {index: 24, cost: 200 * (1 - global.archipelago.shopDiscountPercentage)}
  ]
} else if (shop != noone) {
  shop.shop_data = [
    {index: 2, cost: 100 * (1 - global.archipelago.shopDiscountPercentage)},
    {index: 3, cost: 90 * (1 - global.archipelago.shopDiscountPercentage)},
    {index: 9, cost: 130 * (1 - global.archipelago.shopDiscountPercentage)}
  ]
}

-- apply weapon upgrade discount
let blacksmith = instance_find(oshop_blacksmith, 0)
if (blacksmith != noone) {
  blacksmith.costs = [
    250 * (1 - global.archipelago.shopDiscountPercentage),
    400 * (1 - global.archipelago.shopDiscountPercentage),
    700 * (1 - global.archipelago.shopDiscountPercentage),
    9999
  ]
}
